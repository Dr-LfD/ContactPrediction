# Copy to `.env` and source it (or export in your shell) before running. Paths in
# .vscode/launch.json args and README examples reference ${WS_ROOT} -- export it so
# both your shell and VS Code inherit it. Unset variables are left literal and fail
# loudly (never silently wrong).
#
# REPO_ROOT is computed from the committed `.repo_root` marker (no setup needed) and
# HOME is provided by the OS, so neither is listed here.

# Generic workspace root for non-repo data dirs only -- raw aloha data, rollout
# dumps, and dmg datasets referenced by gen_dataset --mode sg_info.
export WS_ROOT=/path/to/your/workspace
